# Copy to .env.local and fill with values from Firebase Console → Project settings → Your apps.
# Map each VITE_* variable to the matching field in the firebaseConfig object.
# Do not commit .env.local.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
# Firebase Console → Project settings → Cloud Messaging → Web Push certificates
VITE_FIREBASE_VAPID_KEY=
# Geoapify → MyProjects → API Keys (restrict by HTTP referrer in production)
VITE_GEOAPIFY_API_KEY=
# Optional. Cloud Functions region (default: europe-west1). Must match FUNCTIONS_REGION.
# VITE_FIREBASE_FUNCTIONS_REGION=europe-west1
# Optional. Prefix for browser localStorage keys (default: VITE_FIREBASE_PROJECT_ID).
# VITE_APP_STORAGE_PREFIX=your-project-id
# Optional. Firebase Emulator Suite — see docs/emulators.md and .env.emulator.example.
# VITE_USE_FIREBASE_EMULATORS=true
# Optional. Functions emulator only (legacy; prefer VITE_USE_FIREBASE_EMULATORS).
# VITE_FUNCTIONS_EMULATOR=true

# Privacy policy generation (npm run generate:privacy / build). Not exposed to the browser except VITE_PRIVACY_POLICY_ENABLED.
# PRIVACY_INSTANCE_NAME=Queima Asfalto
# PRIVACY_CONTROLLER_NAME=Your name or organisation
# PRIVACY_CONTACT_EMAIL=privacy@example.org
# PRIVACY_HOSTING_URL=https://your-project.web.app
# PRIVACY_RETENTION_POLICY_PT=Pedidos de apagamento por email; resposta em até 30 dias.
# PRIVACY_RETENTION_POLICY_EN=Erasure requests by email; response within 30 days.
# PRIVACY_REQUIRED=true
