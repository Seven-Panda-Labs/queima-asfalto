{
  "name": "queima-asfalto",
  "version": "1.11.0",
  "license": "AGPL-3.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run sync:parkrun-events && npm run generate:privacy && tsc -b && vite build",
    "sync:parkrun-events": "tsx scripts/sync-parkrun-events.ts",
    "generate:privacy": "tsx scripts/generate-privacy-policy.ts",
    "lint": "oxlint",
    "licenses": "license-checker-rseidelsohn --production --summary && license-checker-rseidelsohn --start ./functions --production --summary",
    "check:changelog": "tsx scripts/verify-changelog.ts",
    "check:licenses": "tsx scripts/verify-licenses.ts",
    "check": "npm --prefix functions run build && npm run lint && npm run test && npm run test:rules && npm run check:changelog",
    "setup:githooks": "git config core.hooksPath .githooks",
    "test": "vitest run",
    "test:rules": "firebase emulators:exec --only firestore --project demo-queima-asfalto \"vitest run --config vitest.config.rules.ts\"",
    "preview": "vite preview",
    "emulators": "firebase emulators:start --project demo-queima-asfalto",
    "deploy": "npm run build && firebase deploy --only hosting,firestore:rules,firestore:indexes,storage,functions",
    "deploy:hosting": "npm run build && firebase deploy --only hosting"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "chart.js": "^4.5.1",
    "firebase": "^12.15.0",
    "i18next": "^26.3.3",
    "leaflet": "^1.9.4",
    "react": "^19.2.7",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-leaflet": "^5.0.0",
    "react-leaflet-cluster": "^4.1.3",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.3.1",
    "xlsx": "npm:@stackline/xlsx@^1.0.3"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "firebase-tools": "^15.22.3",
    "jsdom": "^29.1.1",
    "license-checker-rseidelsohn": "^4.4.2",
    "oxlint": "^1.69.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@opentelemetry/core": "^2.8.0",
    "js-yaml": "^4.3.0",
    "uuid": "^11.1.1"
  }
}
