# Copy to functions/.env (not committed). Loaded by Firebase CLI during deploy.
#
# Cloud Functions region. Must match VITE_FIREBASE_FUNCTIONS_REGION in the web app.
# FUNCTIONS_REGION=europe-west1
#
# Optional. Email of the service account used by callable functions (shares, lookup).
# Find it in Firebase Console → Project settings → Service accounts.
# If omitted, Firebase uses the project default runtime service account.
# FUNCTIONS_SERVICE_ACCOUNT=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
#
# Time zone for the scheduled reminders function.
# SCHEDULER_TIMEZONE=Europe/Lisbon
