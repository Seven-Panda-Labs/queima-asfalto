# Copy to .env.local for local development with Firebase Emulators (no cloud project).
# See docs/emulators.md for setup. Do not commit .env.local.
#
# Terminal 1: npm run emulators
# Terminal 2: npm run dev

VITE_USE_FIREBASE_EMULATORS=true

# Placeholder values — must match --project in npm run emulators (demo-queima-asfalto).
VITE_FIREBASE_API_KEY=demo-api-key
VITE_FIREBASE_AUTH_DOMAIN=localhost
VITE_FIREBASE_PROJECT_ID=demo-queima-asfalto
VITE_FIREBASE_STORAGE_BUCKET=demo-queima-asfalto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:demo
VITE_FIREBASE_MEASUREMENT_ID=G-DEMO

# Optional. Location autocomplete (not emulated).
# VITE_GEOAPIFY_API_KEY=

# Optional. Web Push does not work against emulators.
# VITE_FIREBASE_VAPID_KEY=
